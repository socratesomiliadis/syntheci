{
  "name": "syntheci",
  "version": "0.1.0",
  "private": true,
  "description": "Syntheci hackathon MVP monorepo",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @syntheci/web dev",
    "dev:worker": "pnpm --filter @syntheci/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @syntheci/db db:migrate",
    "db:generate": "pnpm --filter @syntheci/db db:generate",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v"
  }
}
